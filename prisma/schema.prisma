generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum ChannelType {
  INSTAGRAM
  FACEBOOK
  X
  TIKTOK
  YOUTUBE
  THREADS
  NAVER_BLOG
  NAVER_CAFE
  KAKAO
  EMAIL
  SMS
  // 글로벌 SNS — 캡션 포맷 지원, 발행 어댑터는 단계별 추가
  WEIBO
  XIAOHONGSHU
  VK
  LINE
  WHATSAPP
  PINTEREST
  DOUYIN
  LINKEDIN
  // 블로그 — 한국·글로벌
  TISTORY
  WORDPRESS
  // HTTP-only API 채널 (에이전트 거치지 않고 Vercel 서버에서 직접 publish)
  TELEGRAM
  DISCORD
}

// Webhook 외부 트리거 토큰 (sns-auto-platform webhook.py 포팅).
// 사용자별 토큰 발급 → /api/webhook/[token]/publish 로 외부에서 캠페인 생성 트리거.
// Zapier · Make · 자체 자동화 통합용.
// rate limit: 분당 60회 · 일 200회 (UserWebhookHit 카운터로 추적).
model UserWebhookToken {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String           @unique // 32자 random hex
  label      String? // 사용자가 식별용 라벨 (예: "Zapier 연동")
  enabled    Boolean          @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime         @default(now())
  hits       UserWebhookHit[]

  @@index([userId])
}

// rate limit 카운터 — 분당/일별 키.
// bucketKey: 'YYYYMMDDHHMM' (분) 또는 'YYYYMMDD' (일) — uniq 조합으로 incr.
model UserWebhookHit {
  id         String           @id @default(cuid())
  tokenId    String
  token      UserWebhookToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  bucketKey  String // YYYYMMDDHHMM (분) 또는 YYYYMMDD (일)
  bucketType String // 'minute' | 'day'
  count      Int              @default(0)
  updatedAt  DateTime         @updatedAt

  @@unique([tokenId, bucketKey, bucketType])
  @@index([updatedAt])
}

// 캠페인 드래프트 — 작성 중 30초 idle 자동 저장 (sns-auto-platform drafts.py 포팅).
// 같은 사용자 1개만 유지 (slot 'campaign'). 30일 후 자동 정리.
model CampaignDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot      String   @default("campaign") // 'campaign' | 'post' | 'image' (확장용)
  payload   Json // form 전체 상태 (name/description/channelIds/content/scheduledAt 등)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, slot])
  @@index([updatedAt])
}

enum ChannelStatus {
  ACTIVE
  PAUSED
  ERROR
  PENDING_AUTH
}

enum TaskStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  name                  String?
  role                  UserRole  @default(USER)
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Phase 6 — 활성 Workspace ID (다중 브랜드 지원).
  // null 이면 user 기본 (개인) 워크스페이스 사용. 채널/캠페인 모델은
  // 추후 단계에서 workspaceId 컬럼 추가 (현재는 userId 유지 — 호환성).
  currentWorkspaceId String?

  channels             MarketingChannel[]
  campaigns            Campaign[]
  agents               AgentInstance[]
  licenses             License[]
  aiConfig             UserAiConfig?
  drafts               CampaignDraft[]
  webhookTokens        UserWebhookToken[]
  ownedWorkspaces      Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  subscription         Subscription?
  campaignSeries       CampaignSeries[]

  // Phase 13 — 리셀러 추천 트래킹.
  // referredByCodeId: 가입 시 ?ref=CODE 쿼리에서 해석된 ReferralCode.id.
  // reseller: 이 사용자가 리셀러로 등록한 경우 1:1 관계.
  referredByCodeId String?
  referredByCode   ReferralCode? @relation("ReferredByCode", fields: [referredByCodeId], references: [id])
  reseller         Reseller?

  // Phase 20 — 인앱 알림
  notifications Notification[]

  // Phase 22 — Web Push 구독
  pushSubscriptions PushSubscription[]

  // Phase 24 — 콘텐츠 라이브러리·활동 피드·외부 알림 채널
  captionTemplates     CaptionTemplate[]
  activities           ActivityLog[]
  notificationChannels UserNotificationChannel[]

  // Phase 25 — 사용자 피드백
  feedbacks UserFeedback[]

  emailPreferences Json @default("{\"failures\": true, \"weekly\": true, \"welcome\": true}")

  // Phase 50 — 같은 PC 에서 비밀번호 없이 다른 계정으로 빠르게 전환하기 위한 토큰.
  trustedDevices TrustedDevice[]
}

// Phase 50 — 같은 PC 에서 한 번 비밀번호로 인증한 계정은 7일간 비번 없이 전환 허용.
// raw token 은 클라이언트의 httpOnly cookie 에만 보관, DB 에는 bcrypt 해시만.
// cookie 가 없거나 hash 매칭 실패 시 그냥 일반 로그인 흐름으로 fallback.
model TrustedDevice {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String
  expiresAt  DateTime
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// 다중 브랜드/회사 격리 (Phase 6) — 한 사용자가 여러 워크스페이스에 소속 가능.
// 향후 채널/캠페인/license 모델에 workspaceId 추가하여 데이터 분리.
// 현재는 모델만 정의 + 사용자가 직접 워크스페이스 생성/전환 가능.
model Workspace {
  id            String                @id @default(cuid())
  name          String
  slug          String                @unique // URL 친화 식별자 (e.g., 'my-startup')
  ownerId       String
  owner         User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // 플랜·결제는 향후 Workspace 단위로 이전. 현재는 User 단위 라이센스 그대로.
  plan          String                @default("FREE")
  // 메타: 로고/색상/설명 (브랜드 정보)
  logoUrl       String?
  brandColor    String?               @default("#1D1D1B")
  description   String?
  members       WorkspaceMember[]
  invitations   WorkspaceInvitation[]
  partnerClient PartnerClient?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([ownerId])
}

// Workspace 의 멤버십 — userId × workspaceId unique. role 별 권한.
model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER
  invitedBy   String?
  joinedAt    DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

// Stripe 구독 (Phase 12) — User 1개당 1개 활성 subscription.
// plan: FREE / STARTER / PRO / BUSINESS
// 이벤트 처리: /api/stripe/webhook 가 customer.subscription.* 처리해서 갱신.
// 만료/취소 시 plan='FREE' 로 자동 강등.
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("FREE") // FREE / STARTER / PRO / BUSINESS
  status               String    @default("active") // active / trialing / past_due / canceled / unpaid
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

model License {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String    @unique
  plan       String    @default("FREE")
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model MarketingChannel {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Phase 18 — 워크스페이스별 격리. null = 사용자 개인 작업 (호환성 유지).
  workspaceId          String?
  type                 ChannelType
  accountName          String
  encryptedCredentials String        @db.Text
  status               ChannelStatus @default(PENDING_AUTH)
  // 다지역 발행 — sns-auto-platform 의 "계정 region 별 자동 언어 라우팅" 포팅.
  // region: korea/usa/japan/china/europe/latam/middle_east/africa/india/southeast_asia/russia/oceania
  // language: ko/en/ja/zh/ar/es/pt/fr/de/ru/hi/id/th/vi
  // 한 캠페인이 여러 region 채널에 발행되면 translator.translateForRegions 가 자동 번역.
  region               String        @default("korea")
  language             String        @default("ko")
  lastUsedAt           DateTime?
  // Phase 50 — 채널별 즉시 인증 (verify task) 메타.
  // lastVerifiedAt: 최근 성공한 verify task 의 finishedAt (UI "마지막 인증" 표시용).
  // verifyError:    최근 실패한 verify task 의 errorLog (status=ERROR 일 때 사유 노출).
  lastVerifiedAt       DateTime?
  verifyError          String?       @db.Text
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  scheduledTasks ScheduledTask[]
  verifyTasks    ChannelVerifyTask[]

  @@index([userId])
  @@index([userId, workspaceId])
  @@index([type])
  @@index([region])
}

// Phase 50 — 채널 즉시 인증 task (발행과 별도).
// 채널 추가/자격증명 수정/사용자 "재인증" 클릭 시 PENDING 으로 enqueue.
// 에이전트가 polling 시 ScheduledTask 와 함께 받음 → IG 등 브라우저 자동화 채널은
// 브라우저 띄워 사용자 직접 로그인 → 결과를 /api/agent/result 에 보고.
// 결과 따라 MarketingChannel.status (ACTIVE/ERROR), lastVerifiedAt, verifyError 갱신.
// ScheduledTask 와 별도 모델인 이유: ScheduledTask 는 campaignId/content 필수.
model ChannelVerifyTask {
  id         String           @id @default(cuid())
  channelId  String
  channel    MarketingChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  status     TaskStatus       @default(PENDING)
  errorLog   String?          @db.Text
  agentId    String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([channelId])
  @@index([status, createdAt])
}

model Campaign {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Phase 18 — 워크스페이스별 격리. null = 사용자 개인.
  workspaceId String?
  name        String
  description String?
  status      String    @default("DRAFT")
  scheduledAt DateTime?
  completedAt DateTime?
  // Phase 26 — 태그 (검색·필터·분석용). 공백 구분 또는 JSON string array.
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Phase 9: 자동화 시리즈가 만든 캠페인 — 정확한 매핑 (이전 description 매칭 대체)
  seriesId String?
  series   CampaignSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  tasks ScheduledTask[]

  @@index([userId])
  @@index([userId, workspaceId])
  @@index([seriesId])
  @@index([tags])
}

model ScheduledTask {
  id          String           @id @default(cuid())
  campaignId  String
  campaign    Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channelId   String
  channel     MarketingChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  content     String           @db.Text
  mediaUrls   Json?
  scheduledAt DateTime
  executedAt  DateTime?
  status      TaskStatus       @default(PENDING)
  errorLog    String?          @db.Text
  agentId     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([campaignId])
  @@index([channelId])
  @@index([status, scheduledAt])
}

// 자동화 시리즈 (Phase 8-2) — 한 번 설정하면 며칠/몇주 동안 자동 발행.
//
// mode 옵션:
//   POOL_VARY:     사용자가 mediaPool 업로드 → 매번 1장 + AI 가 다른 캡션 (다양성 高)
//   AI_FRESH:      이미지 + 캡션 모두 매번 새로 생성 (가장 다양, 노이즈 위험)
//   POOL_SIMILAR:  mediaPool 에서 1장 + 같은 톤·스타일의 캡션 (브랜드 일관성)
//   PARAPHRASE:    contentSeed 본문을 매번 paraphrase (같은 메시지 반복)
//
// schedule 옵션:
//   INTERVAL:      intervalHours 시간마다 (예: 3시간마다)
//   DAILY:         매일 dailyTimes 의 시각들에 (예: ['09:00','12:00','19:00'])
//   WEEKLY:        weeklyDays + dailyTimes (예: 월·수·금 + 10:00)
//   FIXED_COUNT:   startAt~endAt 사이에 totalPosts 개 자동 분배 (균등 또는 prime-time)
//
// 처리: /api/cron/dispatch-series 가 5분마다 RUNNING 시리즈 확인.
//   - nextRunAt <= now 이면 콘텐츠 1개 생성 → ScheduledTask 생성 → completedPosts++
//   - 다음 nextRunAt 계산해서 갱신
//   - completedPosts >= totalPosts 면 status='COMPLETED'
model CampaignSeries {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Phase 18 — 워크스페이스별 격리. null = 사용자 개인.
  workspaceId         String?
  name                String
  channelIds          Json // string[] — 발행 대상 채널들
  // Phase 11 — 새 mode: POOL / AI_IMAGE / AI_VIDEO
  // 기존 호환: POOL_VARY/POOL_SIMILAR → POOL (captionStyle 로 분기), AI_FRESH → AI_IMAGE, PARAPHRASE → 미지원
  mode                String    @default("POOL")
  // POOL 모드 시 글 스타일 — VARY (매번 다른) / SIMILAR (일관)
  captionStyle        String?   @default("VARY")
  // 콘텐츠 카테고리 — SNS (짧은 글 + 1장) / BLOG (긴 글 + 여러 장)
  contentCategory     String?   @default("SNS")
  scheduleType        String    @default("DAILY") // INTERVAL / DAILY / WEEKLY / FIXED_COUNT
  intervalHours       Int? // INTERVAL 모드 (예: 3)
  dailyTimes          Json? // DAILY/WEEKLY 모드 — string[] (HH:mm 배열)
  weeklyDays          Json? // WEEKLY 모드 — number[] (0=일 ~ 6=토)
  totalPosts          Int       @default(10)
  completedPosts      Int       @default(0)
  failedPosts         Int       @default(0)
  // 콘텐츠 소스
  mediaPool           Json? // string[] (R2 URL 배열) — POOL_VARY/POOL_SIMILAR 모드
  contentSeed         String?   @db.Text // PARAPHRASE/POOL_SIMILAR/AI_FRESH 시드 본문
  briefData           Json? // ContentBrief (purpose/tone/audience/cta 등)
  // 일정
  status              String    @default("DRAFT") // DRAFT / RUNNING / PAUSED / COMPLETED / FAILED
  startAt             DateTime  @default(now())
  endAt               DateTime?
  nextRunAt           DateTime? // 다음 발행 시점 (cron 워커가 사용)
  lastRunAt           DateTime?
  lastError           String?   @db.Text
  // Phase 9 — 알림 한 번만 발송 (반복 알림 방지)
  notifiedCompletedAt DateTime?
  // Phase 26 — 태그
  tags                String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  campaigns Campaign[]

  @@index([userId])
  @@index([userId, workspaceId])
  @@index([tags])
  @@index([status, nextRunAt])
}

model AgentInstance {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Phase 18 — 워크스페이스별 격리. null = 사용자 개인.
  workspaceId String?
  machineId   String   @unique
  name        String?
  version     String
  os          String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, workspaceId])
}

// ════════════════════════════════════════════════════════════
//  AI / Translate / Image-gen — sns-auto-platform 포팅
// ════════════════════════════════════════════════════════════

// 사용자별 AI 엔진 설정 (sns-auto-platform engine_config.py 의 Redis 저장을 Prisma로 포팅)
// - aiPriority: 전역 폴백 순서 (예: ['gemini','groq','ollama','claude'])
// - aiModels: 엔진별 선택 모델
// - aiKeys: 사용자가 직접 등록한 API 키 (env보다 우선) — 단방향 암호화 필요 (lib/crypto encryptCredentials 재사용)
// - taskPriorities: task별 폴백 순서 (vision/blog_long/sns_short/micro_280/business_cta/video_meta/image_gen/video_gen)
// - translationPriority: 번역 엔진 순서 (deepl/libretranslate/ai)
// - utm: 발행 시 자동 append할 UTM 파라미터
// - monthlyBudgetUsd: 0=한도없음, >0이면 초과 시 유료 엔진 자동 skip
model UserAiConfig {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiPriority          Json     @default("[\"gemini\",\"groq\",\"ollama\",\"claude\"]")
  aiModels            Json     @default("{}")
  aiKeysEncrypted     String?  @db.Text
  taskPriorities      Json     @default("{}")
  translationPriority Json     @default("[\"deepl\",\"libretranslate\",\"ai\"]")
  deeplPro            Boolean  @default(false)
  utm                 Json     @default("{}")
  monthlyBudgetUsd    Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// 번역 캐시 (sns-auto-platform Redis 'translate:cache:*' 를 Prisma로 포팅)
// hash = md5("{sourceLang}|{targetLang}|{text}") — 같은 (src,tgt,text)는 캐시 재사용
// expiresAt 기준 만료 (기본 30일). 만료된 행은 cron에서 정리.
model TranslationCache {
  id         String   @id @default(cuid())
  hash       String   @unique
  sourceLang String
  targetLang String
  translated String   @db.Text
  engine     String // deepl/libretranslate/ai-groq/ai-claude/ai-ollama
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

// 사용량 카운터 (sns-auto-platform Redis 'usage:*' 키 포팅) — 예산 초과 판정용
// scope: 'global' | userId — 전역과 사용자별 동시 추적 가능
// kind: 'image_gen' | 'video_gen' | 'translate' | 'caption'
// engine: 'pollinations' | 'openai' | 'gemini' | 'groq' | 'claude' | 'ollama' | 'deepl' | 'libretranslate' | 'ai'
model AiUsageCounter {
  id        String   @id @default(cuid())
  scope     String // 'global' or userId
  kind      String // image_gen / video_gen / translate / caption
  engine    String
  count     Int      @default(0)
  monthKey  String // 'YYYY-MM' for budget reset
  updatedAt DateTime @updatedAt

  @@unique([scope, kind, engine, monthKey])
  @@index([scope, monthKey])
}

// ════════════════════════════════════════════════════════════
//  Phase 13 — 리셀러 / 추천 (referral) 모델
//
// 모델: amakers.co.kr 가 직접 사용자와 계약, 리셀러는 추천 수수료만 받음 (affiliate 모델).
//   - 리셀러 등록 → 자동으로 ReferralCode 1개 생성 (예: "DESIGN-KIM-A1B2")
//   - 신규 사용자가 ?ref=CODE 로 가입하면 user.referredByCodeId 에 저장
//   - 매월 1일 cron 이 지난달 사용자 결제액 × commissionRate 만큼 ReferralCommission 생성
//   - 관리자가 PAID 처리 후 송금 (개인은 3.3% 원천징수, 사업자는 세금계산서)
// ════════════════════════════════════════════════════════════

model Reseller {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  contactEmail   String
  taxStatus      String   @default("INDIVIDUAL") // INDIVIDUAL | BUSINESS
  businessNumber String?
  bankAccount    String?
  commissionRate Float    @default(0.10) // 0.10 = 10%
  status         String   @default("ACTIVE") // ACTIVE | SUSPENDED
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referralCodes ReferralCode[]
  commissions   ReferralCommission[]
  clients       PartnerClient[]

  @@index([status])
}

model ReferralCode {
  id          String   @id @default(cuid())
  code        String   @unique // ex: "DESIGN-KIM-A1B2"
  resellerId  String
  reseller    Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  referrals User[] @relation("ReferredByCode")

  @@index([resellerId])
  @@index([active])
}

model ReferralCommission {
  id              String    @id @default(cuid())
  resellerId      String
  reseller        Reseller  @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  referredUserId  String
  periodYearMonth String // "2026-05"
  baseRevenue     Decimal   @db.Decimal(12, 2) // 해당 사용자의 월 결제액 (KRW)
  commissionRate  Float
  amount          Decimal   @db.Decimal(12, 2) // baseRevenue * commissionRate
  status          String    @default("PENDING") // PENDING | PAID | CANCELLED
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())

  @@unique([resellerId, referredUserId, periodYearMonth])
  @@index([resellerId, status])
  @@index([periodYearMonth])
}

// ════════════════════════════════════════════════════════════
//  Phase 14 — PartnerClient (파트너가 대행 관리하는 고객사)
//
// 파트너(=Reseller) 가 여러 고객사의 마케팅을 대신 운영해주는 모델.
// 각 고객사는 별도 Workspace 1개로 격리됨 (채널·캠페인 모두 그 워크스페이스 안).
// 파트너는 워크스페이스의 OWNER 또는 ADMIN 으로 참여하여 작업을 수행.
//
// monthlyFee: 파트너가 고객사에게 받는 월 관리비 (별도 — 자체 청구).
// status: ACTIVE | PAUSED | CHURNED
// ════════════════════════════════════════════════════════════

model PartnerClient {
  id           String    @id @default(cuid())
  partnerId    String // → Reseller.id
  partner      Reseller  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  workspaceId  String    @unique // 1:1 — 각 고객사는 워크스페이스 1개
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientName   String // 고객사 표시 이름 (예: "스타트업 A 카페")
  contactName  String?
  contactEmail String?
  contactPhone String?
  industry     String? // 카페 / 식당 / 헬스장 / 의류 등
  monthlyFee   Int? // 파트너 자체 청구액 (원)
  status       String    @default("ACTIVE") // ACTIVE | PAUSED | CHURNED
  notes        String?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  reports  PartnerClientReport[]
  invoices ClientInvoice[]

  @@index([partnerId, status])
}

// ════════════════════════════════════════════════════════════
//  Phase 17 — WorkspaceInvitation
//
// 워크스페이스에 미가입 사용자도 초대 가능 (이메일 + 가입 토큰).
// 초대 받은 이메일이 가입하면 자동으로 워크스페이스 멤버로 추가됨.
//
// flow:
//   1. 파트너가 client@example.com 초대 → token 생성 + 이메일 발송
//   2. 받은 이는 /invite/<token> 클릭
//   3. 로그인 상태면 즉시 멤버로 추가 / 비로그인이면 가입 후 자동 추가
//   4. expiresAt 지나면 자동 만료 (cron 으로 정리 또는 lazy)
// ════════════════════════════════════════════════════════════

model WorkspaceInvitation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String // 초대받는 이메일 (소문자)
  role        String    @default("MEMBER") // ADMIN | MEMBER | VIEWER
  token       String    @unique // 32자 random hex
  invitedBy   String // userId
  message     String? // 초대 메시지 (선택)
  status      String    @default("PENDING") // PENDING | ACCEPTED | REVOKED | EXPIRED
  expiresAt   DateTime // 7일 후 기본
  acceptedAt  DateTime?
  acceptedBy  String? // userId of acceptor
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, email])
  @@index([token])
  @@index([email, status])
}

// ════════════════════════════════════════════════════════════
//  Phase 19 — PartnerClientReport (월간 자동 PDF 리포트)
//
// Gold+ 등급 파트너 혜택 — 매월 1일 cron 이 활성 고객사별로 자동 생성.
// 발행수·채널 분포·성과 요약을 PDF 로 만들어 R2 에 업로드 → URL 보관.
// 파트너가 다운로드 후 고객사에게 전달 가능.
// ════════════════════════════════════════════════════════════

model PartnerClientReport {
  id                    String        @id @default(cuid())
  partnerClientId       String // → PartnerClient.id
  partnerClient         PartnerClient @relation(fields: [partnerClientId], references: [id], onDelete: Cascade)
  periodYearMonth       String // "2026-05"
  // 통계 (PDF 내용 + 빠른 조회용 캐시)
  totalCampaigns        Int           @default(0)
  totalPublished        Int           @default(0) // 성공한 task 수
  totalFailed           Int           @default(0)
  channelMix            Json? // { instagram: 12, naver_blog: 8, ... }
  topPerformingCampaign String? // 가장 성공한 캠페인 이름
  // 파일
  pdfUrl                String? // R2 public URL
  pdfSizeKb             Int?
  generatedAt           DateTime      @default(now())
  generatedBy           String        @default("cron") // 'cron' | 'manual'
  // 상태
  status                String        @default("READY") // GENERATING | READY | FAILED
  errorMessage          String?
  createdAt             DateTime      @default(now())

  @@unique([partnerClientId, periodYearMonth])
  @@index([partnerClientId, periodYearMonth])
}

// ════════════════════════════════════════════════════════════
//  Phase 20 — 인앱 알림 센터
//
// 헤더 벨 아이콘 드롭다운으로 표시. 이메일 알림과 동시에 발생.
// kind: REFERRAL_NEW (추천 사용자 가입) / COMMISSION_NEW (commission 누적)
//       TIER_UPGRADE (등급 승급) / WORKSPACE_INVITE (워크스페이스 초대 도착)
//       SERIES_COMPLETE (시리즈 완료) / SYSTEM (공지)
// ════════════════════════════════════════════════════════════

model Notification {
  id        String    @id @default(cuid())
  userId    String // 알림 받는 사용자
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // REFERRAL_NEW | COMMISSION_NEW | TIER_UPGRADE | WORKSPACE_INVITE | SERIES_COMPLETE | SYSTEM
  title     String // 짧은 제목
  body      String? // 본문 (선택)
  link      String? // 클릭 시 이동 URL (예: /dashboard/partner)
  metadata  Json? // 추가 데이터 (예: { resellerId, amount })
  readAt    DateTime? // null = 안 읽음
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ════════════════════════════════════════════════════════════
//  Phase 21 — ClientInvoice (파트너가 고객사에게 발행하는 인보이스)
//
// 파트너가 고객사 대행 마케팅의 월 관리비 청구서를 발행.
// amakers 결제 (Stripe) 와는 별개 — 파트너 ↔ 고객사 간 자체 청구.
// 추후 Stripe Connect 통합 시 자동 결제 가능 (현재는 수동 송금 트래킹).
// ════════════════════════════════════════════════════════════

model ClientInvoice {
  id              String        @id @default(cuid())
  partnerClientId String
  partnerClient   PartnerClient @relation(fields: [partnerClientId], references: [id], onDelete: Cascade)
  invoiceNumber   String // "INV-2026-05-001"
  periodYearMonth String // "2026-05"
  amount          Int // 원 단위 (KRW)
  vat             Int           @default(0) // 부가세 (10%)
  total           Int // amount + vat
  description     String?       @db.Text // 인보이스 항목 설명
  status          String        @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE | CANCELLED
  dueDate         DateTime?
  sentAt          DateTime?
  paidAt          DateTime?
  paymentMethod   String? // BANK_TRANSFER | CARD | CASH
  paymentNotes    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([partnerClientId, invoiceNumber])
  @@index([partnerClientId, status])
  @@index([periodYearMonth])
}

// ════════════════════════════════════════════════════════════
//  Phase 22 — Web Push Subscription (브라우저 푸시 알림)
//
// 사용자 디바이스/브라우저별 push subscription 저장.
// VAPID 키 (env: VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY) 필수.
// 알림 발생 시 인앱 + 이메일 + Web Push 동시 처리 (각각 독립).
// ════════════════════════════════════════════════════════════

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique // 브라우저별 unique URL
  p256dh    String // 클라이언트 공개키
  authKey   String // 인증 secret
  userAgent String? // 식별용
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  @@index([userId])
}

// ════════════════════════════════════════════════════════════
//  Phase 24 — CaptionTemplate (재사용 가능한 캡션·콘텐츠 템플릿)
//
// 사용자가 자주 쓰는 캡션·해시태그 모음·CTA 패턴을 라이브러리에 저장.
// 캠페인 작성 시 클릭으로 즉시 불러와 사용.
// 워크스페이스별로 격리 (다른 고객사용 템플릿 분리).
// ════════════════════════════════════════════════════════════

model CaptionTemplate {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String? // null = 사용자 개인
  name        String // 템플릿 이름 (예: "신메뉴 출시")
  body        String    @db.Text // 캡션 본문
  hashtags    String? // 해시태그 (공백 구분)
  category    String? // 카페·식당·뷰티 등
  usageCount  Int       @default(0) // 사용 횟수 — 정렬·인기도
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, workspaceId])
  @@index([userId, usageCount(sort: Desc)])
}

// ════════════════════════════════════════════════════════════
//  Phase 24 — ActivityLog (팀 활동 피드)
//
// 워크스페이스 내 모든 멤버 활동 기록.
// 캠페인 생성·발행·채널 등록 등 — 멤버 협업 시 누가 뭐 했는지 추적.
// ════════════════════════════════════════════════════════════

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String // 행위자
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String? // null = 사용자 개인 작업
  kind        String // CAMPAIGN_CREATED · CHANNEL_ADDED · SERIES_STARTED 등
  title       String // "신메뉴 캠페인 작성"
  body        String? // 상세 (선택)
  link        String? // 클릭 시 이동
  metadata    Json? // 추가 데이터
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// ════════════════════════════════════════════════════════════
//  Phase 24 — UserNotificationChannel (외부 알림 채널 — Slack/Discord)
//
// 사용자 본인 또는 팀 채널로 외부 webhook 알림 발송.
// 인앱 알림이 발생하면 자동으로 함께 전송.
// ════════════════════════════════════════════════════════════

model UserNotificationChannel {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String // SLACK | DISCORD
  webhookUrl String // 외부 webhook URL
  label      String? // 식별용 라벨
  enabled    Boolean   @default(true)
  // 어떤 종류의 알림을 외부로 보낼지 (kind 화이트리스트). null = 전체.
  kindFilter Json?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId, enabled])
}

// ════════════════════════════════════════════════════════════
//  Phase 25 — UserFeedback
//
// 사용자가 보낸 별점 + 코멘트. 관리자 페이지에서 확인.
// ════════════════════════════════════════════════════════════

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  comment   String?  @db.Text
  context   String? // 어느 페이지에서 보냈는지 (예: '/dashboard')
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rating, createdAt])
}

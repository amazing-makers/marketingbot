{
    "framework": "nextjs",
    "buildCommand": "prisma generate && next build",
    "regions": ["icn1"],
    "crons": [
        { "path": "/api/health", "schedule": "0 0 * * *" },
        { "path": "/api/cron/email-task-summary", "schedule": "0 0 * * *" },
        { "path": "/api/cron/email-weekly-report", "schedule": "0 0 * * 1" },
        { "path": "/api/cron/recover-zombie-tasks", "schedule": "*/5 * * * *" },
        { "path": "/api/cron/dispatch-cloud-publishers", "schedule": "*/5 * * * *" },
        { "path": "/api/cron/cleanup-drafts", "schedule": "0 18 * * *" }
      ]
}
